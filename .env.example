# ── Required ──────────────────────────────────────────────────────────────────
# Target Metabase instance URL (no trailing slash)
METABASE_URL=https://metabase.example.com

# ── Authentication — default credentials for unauthenticated connections ──────
# Option A: API Key (recommended — create in Metabase Admin → API Keys)
# METABASE_API_KEY=mb_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Option B: Email + Password
# METABASE_USER_EMAIL=admin@example.com
# METABASE_PASSWORD=your-password

# ── Server settings ───────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
MCP_PATH=/mcp

# How long (seconds) to cache each user's MetabaseClient connection (default 1 h)
CLIENT_CACHE_TTL=3600
