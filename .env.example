# ── Required ──────────────────────────────────────────────────────────────────
# Target Metabase instance URL (no trailing slash)
METABASE_URL=https://metabase.example.com

# ── Authentication ─────────────────────────────────────────────────────────────
# Option A: base64url encoded credentials (recommended — avoids plaintext)
#   Generate:
#     API Key  : echo -n 'apikey:mb_xxxx'            | base64 | tr '+/' '-_' | tr -d '='
#     Email    : echo -n 'alice@example.com:password' | base64 | tr '+/' '-_' | tr -d '='
# METABASE_CREDENTIALS=YXBpa2V5Om1iX3h4eHg

# Option B: plaintext API Key
# METABASE_API_KEY=mb_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Option C: plaintext Email + Password
# METABASE_USER_EMAIL=admin@example.com
# METABASE_PASSWORD=your-password

# ── HTTP Proxy for outbound Metabase API requests ─────────────────────────────
# When set, uses this proxy for all requests to METABASE_URL.
# When NOT set (default), no proxy is used — HTTP_PROXY / HTTPS_PROXY env vars
# are explicitly IGNORED.
# METABASE_HTTP_PROXY=http://proxy.internal:3128

# ── Transport ─────────────────────────────────────────────────────────────────
# stdio  — for local MCP clients (Claude Desktop, Claude Code)
# http   — for remote / multi-user HTTP access (default)
TRANSPORT=http

# ── Server settings (http transport only) ────────────────────────────────────
HOST=0.0.0.0
PORT=8000
MCP_PATH=/mcp

# How long (seconds) to cache each user's MetabaseClient connection (default 1 h)
CLIENT_CACHE_TTL=3600

# ── Named Metabase instances (for cross-instance migration) ─────────────────
# Comma-separated list of instance identifiers.
# Each instance is configured via METABASE_{NAME}_URL, METABASE_{NAME}_EMAIL,
# METABASE_{NAME}_PASSWORD, METABASE_{NAME}_API_KEY, or
# METABASE_{NAME}_CREDENTIALS (base64url-encoded, same format as METABASE_CREDENTIALS).
#
# Example: two instances "hz" and "sg"
# METABASE_INSTANCES=hz,sg
# METABASE_HZ_URL=https://metabase-hz.example.com
# METABASE_HZ_API_KEY=mb_hz_xxxx
# METABASE_SG_URL=https://metabase-sg.example.com
# METABASE_SG_API_KEY=mb_sg_xxxx
#
# Then use migrate_collection with source_instance="hz", target_instance="sg".
